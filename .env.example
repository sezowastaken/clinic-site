NODE_ENV=development

WEB_PORT=8080
API_PORT=3000

POSTGRES_DB=clinic
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinic
DATABASE_URL=postgres://clinic:clinic@db:5432/clinic

SESSION_COOKIE_NAME=clinic_admin_session
SESSION_TTL_DAYS=14

# Optional: only used on API startup to bootstrap the first admin user.
# Leave blank to skip. If set, ADMIN_NAME, ADMIN_EMAIL, and ADMIN_PASSWORD are all required together.
ADMIN_NAME=
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_ROLE=assistant
